{
  "name": "gde-zapravitsya",
  "version": "0.1.0",
  "private": true,
  "description": "Краудсорсинговая карта заправок РФ: наличие топлива, лимиты на руки и очереди в реальном времени",
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:clean": "node scripts/kill-dev-ports.mjs && node scripts/clean-next-cache.mjs && next dev -p 3000",
    "build": "next build",
    "postbuild": "node scripts/copy-standalone-assets.mjs",
    "start": "next start",
    "lint": "next lint",
    "seed": "node scripts/seed-osm.mjs",
    "setup:db": "node scripts/setup-db.mjs",
    "seed:db": "node scripts/seed-supabase.mjs",
    "sync:gdebenz": "node scripts/sync-gdebenz.mjs",
    "sync:gdebenz:comments": "node scripts/sync-gdebenz-comments.mjs",
    "sync:gdebenz:comments:turbo": "node scripts/sync-gdebenz-comments.mjs --all --turbo",
    "indexnow": "node scripts/submit-indexnow.mjs",
    "indexnow:prod": "node scripts/trigger-indexnow-prod.mjs",
    "cities:import": "node scripts/import-gdebenz-cities.mjs && node scripts/fix-city-names.mjs",
    "seo:routes": "node scripts/gen-seo-intent-routes.mjs",
    "seo:keywords": "node scripts/export-seo-keywords.mjs",
    "warm:seo": "node scripts/warm-seo-pages.mjs",
    "check:proxies": "node scripts/check-proxies.mjs",
    "proxy:bridge": "node scripts/proxy-bridge.mjs",
    "deploy": "bash scripts/deploy.sh",
    "icons": "node scripts/gen-icons.mjs",
    "map-assets": "node scripts/fetch-map-assets.mjs",
    "social:export": "node scripts/export-social-logo.mjs"
  },
  "dependencies": {
    "https-proxy-agent": "^9.1.0",
    "maplibre-gl": "^5.24.0",
    "next": "^15.1.6",
    "pg": "^8.13.1",
    "pmtiles": "^4.4.1",
    "protomaps-themes-base": "^4.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socks": "^2.8.9",
    "socks-proxy-agent": "^10.1.0",
    "undici": "^8.5.0"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.2",
    "@emnapi/runtime": "^1.11.2",
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.19",
    "playwright": "^1.61.1",
    "postcss": "^8.4.39",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3"
  }
}
