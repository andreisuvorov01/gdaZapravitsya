# === Локальная разработка (.env не коммитится) ===

# --- Сайт ---
# Канонический URL продакшена (sitemap, OpenGraph)
NEXT_PUBLIC_SITE_URL=https://гдезаправиться.рф

# Донаты (CloudTips / Т-Банк) — кнопка «Поддержать» в шапке
NEXT_PUBLIC_DONATE_URL=https://pay.cloudtips.ru/p/a8cc01dd

# --- Карта (MapLibre, полностью бесплатно, без ключа) ---
# По умолчанию используется OpenFreeMap (тёмный стиль): без ключа, без лимитов, с CORS.
# Ничего настраивать не нужно — работает из коробки.
#
# (Опц.) Свой готовый стиль MapLibre (URL на style.json), напр. self-hosted:
NEXT_PUBLIC_MAP_STYLE=
# (Опц.) Свой self-hosted .pmtiles, отдаваемый напрямую (протокол pmtiles://,
# HTTP Range с внешнего хоста). Если задан — имеет приоритет над style выше.
NEXT_PUBLIC_PMTILES_URL=
# (Опц., рекомендуется) URL ZXY-тайлов от своего `pmtiles serve` (см. docs/TILES.md) —
# напр. "/tiles/russia/{z}/{x}/{y}.mvt", если прокси на том же домене через nginx.
# Имеет приоритет над обоими вариантами выше: ни отдельного хоста, ни CORS не нужно.
# Это детальный слой (только по России, z9-14) — вне её территории он просто
# пустой, поэтому нужен ещё NEXT_PUBLIC_WORLD_TILES_URL ниже.
NEXT_PUBLIC_TILES_URL=
# (Опц.) maxzoom тайлсета из NEXT_PUBLIC_TILES_URL — должен совпадать с --maxzoom
# при extract (по умолчанию 14, см. docs/TILES.md — z15 у источника технически
# есть, но на практике оказался ненадёжным для полной выгрузки по России).
NEXT_PUBLIC_TILES_MAXZOOM=14
# (Опц., но нужен вместе с TILES_URL выше) грубый мировой слой (z0-8, весь мир) —
# без него всё, что за пределами России, будет серым/пустым. См. docs/TILES.md.
NEXT_PUBLIC_WORLD_TILES_URL=

# --- База данных (self-hosted Postgres на том же VPS, что и приложение) ---
# Обычный локальный Postgres + PostGIS (см. db/schema.sql, npm run setup:db).
# Без REST-слоя/Realtime — приложение и скрипты подключаются напрямую через `pg`.
# Слушает только localhost — наружу порт не открывать.
DATABASE_URL=postgresql://benzin_app:[YOUR-PASSWORD]@localhost:5432/benzin

# Импорт OSM по региону (npm run seed)
SEED_BBOX=

# --- Приватный фид для внешних интеграций (app/api/feed/*) — не используется на этом сайте ---
# Стойкая случайная строка: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Передаётся ТОЛЬКО заголовком: curl -H "x-api-key: ..." ".../api/feed/stations?city=krasnodar&fresh=1"
FEED_API_KEY=

# --- Cron-синхронизация (защищённый роут /api/cron/sync-gdebenz) ---
# Стойкая случайная строка. Передаётся заголовком: -H "x-cron-key: ..." или Authorization: Bearer
CRON_SECRET=

# --- IndexNow (Bing, Yandex и др.) — быстрая индексация после деплоя ---
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# Файл верификации: https://гдезаправиться.рф/{INDEXNOW_KEY}.txt (содержимое = ключ)
# Отправка всех URL из sitemap: npm run indexnow
# Cron после деплоя: POST /api/cron/indexnow с заголовком x-cron-key: $CRON_SECRET
INDEXNOW_KEY=

# --- Прокси для scripts/sync-gdebenz.mjs и scripts/sync-gdebenz-comments.mjs ---
# Список через запятую. Схема в URL определяет тип прокси:
#   http://user:pass@host:port    — HTTP(S)-прокси (CONNECT-туннель)
#   socks5://user:pass@host:port  — SOCKS5-прокси
# (без user:pass — если прокси без авторизации). Берутся по кругу — по одному
# на КАЖДУЮ попытку запроса к gdebenz.ru, так что запросы естественным образом
# чередуются между прокси. Не используется нигде, кроме синка с gdebenz.ru
# (подключение к БД не проксируется). Один прокси — тоже сюда, без запятых.
# Проверить, что прокси реально рабочие: node scripts/check-proxies.mjs
PROXY_LIST=

# --- Reverse proxy (nginx на VPS) ---
# true — доверять x-forwarded-for / x-real-ip для rate-limit и client_id.
# Включайте только если прокси перезаписывает эти заголовки (см. DEPLOY.md).
TRUST_PROXY=true

# --- Временный рубильник rate-limit'а ---
# true — полностью отключает все rate-limit/row-budget проверки (bbox, отчёты,
# подтверждения, создание станций). Origin/Referer-фильтр и honeypot не
# затрагиваются. Использовать только временно для диагностики — не оставлять
# включённым на проде дольше необходимого.
DISABLE_RATE_LIMIT=false

# --- Яндекс РСЯ (реклама на контентных страницах, не на карте) ---
# partner.yandex.ru — свой рекламный аккаунт для этого сайта. blockId ниже —
# от аккаунта оригинального форка (benzryadom.ru), оставлены пустыми до
# получения собственных, см. docs/SHARED-INFRA.md.
# NEXT_PUBLIC_YANDEX_RTB_ENABLED=false — временно отключить без удаления blockId.
NEXT_PUBLIC_YANDEX_RTB_BLOCK_TOP=
NEXT_PUBLIC_YANDEX_RTB_BLOCK_INARTICLE=
NEXT_PUBLIC_YANDEX_RTB_BLOCK_FOOTER=

# --- Временный рубильник устаревания данных ---
# true — отчёты никогда не считаются устаревшими: заправки не помечаются
# серым/"нет данных" из-за возраста последнего отчёта (см. lib/freshness.ts).
# NEXT_PUBLIC_, т.к. используется и в клиентских компонентах — меняется
# только при пересборке (next build), просто перезапуска pm2 недостаточно.
NEXT_PUBLIC_DISABLE_STALE_MARKING=false
